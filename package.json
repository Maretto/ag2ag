{
  "name": "ag2ag",
  "version": "0.4.1",
  "description": "Run A2A-compatible agents on a single host. Node.js + systemd. No Docker. No Kubernetes.",
  "main": "index.js",
  "bin": {
    "ag2ag": "./src/cli.js"
  },
  "files": [
    "src/",
    "index.js",
    "LICENSE",
    "NOTICE",
    "SECURITY.md"
  ],
  "keywords": [
    "a2a",
    "a2a-protocol",
    "agent",
    "agents",
    "agent-to-agent",
    "ai-agent",
    "systemd",
    "cli",
    "single-host",
    "self-hosted",
    "localhost",
    "automation",
    "nodejs"
  ],
  "scripts": {
    "test": "node --test test/unit/*.test.js test/concurrency.test.js",
    "test:unit": "node --test test/unit/*.test.js",
    "test:concurrency": "node --test test/concurrency.test.js"
  },
  "dependencies": {
    "@a2a-js/sdk": "^0.3.13"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Maretto/ag2ag.git"
  },
  "homepage": "https://github.com/Maretto/ag2ag",
  "bugs": {
